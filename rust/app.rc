#include <winver.h>

// The icon ID "1" makes Explorer pick this as the application icon.
1 ICON "../ClutterCutter.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 0,0,1,0
 PRODUCTVERSION 0,0,1,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Struis ICT"
            VALUE "FileDescription",  "ClutterCutter (Rust port)"
            VALUE "FileVersion",      "0.0.1"
            VALUE "InternalName",     "cluttercutter"
            VALUE "OriginalFilename", "cluttercutter.exe"
            VALUE "ProductName",      "ClutterCutter"
            VALUE "ProductVersion",   "0.0.1"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
